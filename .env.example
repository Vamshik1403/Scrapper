# =============================================================================
# GarageLeadsPro — Environment Variables TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your real values.
# =============================================================================

# Flask
SECRET_KEY=change-me-to-a-strong-random-string
FLASK_ENV=development

# API Keys
# Single key:
SERPAPI_KEY=your_serpapi_key_here
# Multiple keys (comma-separated) for automatic rotation when one is exhausted:
# SERPAPI_KEY=key1,key2,key3
# Or numbered:
# SERPAPI_KEY_2=your_second_serpapi_key
# SERPAPI_KEY_3=your_third_serpapi_key

OPENAI_KEY=your_openai_api_key_here
# OPENAI_KEY_2=your_second_openai_key

# Your Info (used in outreach emails / PDFs)
YOUR_EMAIL=your@email.com
YOUR_WEBSITE=yourwebsite.com
